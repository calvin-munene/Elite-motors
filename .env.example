# ============================================================
# AutoElite Motors — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit your real `.env` file to git.

# ----- REQUIRED -----

# PostgreSQL database connection string
# Get one free at: https://neon.tech, https://supabase.com, or https://railway.app
DATABASE_URL=postgresql://user:password@host:5432/autoelite

# Random secret used to sign admin session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Port the API server listens on (default 8080)
PORT=8080

# Node environment (development | production)
NODE_ENV=production


# ----- OPTIONAL: AI features -----
# Required for: AI chatbot, visual search, price negotiation,
# voice-to-listing, recommendations, photo enhancement.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...


# ----- OPTIONAL: WhatsApp Cloud API -----
# Required for: WhatsApp notifications & customer chat.
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=


# ----- OPTIONAL: Logging -----
LOG_LEVEL=info
